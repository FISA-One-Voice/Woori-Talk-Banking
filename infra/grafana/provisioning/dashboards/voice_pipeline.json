{
  "title": "음성 파이프라인 현황",
  "uid": "woori-voice-pipeline",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "Asia/Seoul",
  "tags": [
    "woori"
  ],
  "panels": [
    {
      "id": 1,
      "title": "파이프라인 성공률",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/api/voice/voice\",status=\"2xx\"}[5m]) / rate(http_requests_total{handler=\"/api/voice/voice\"}[5m]) * 100",
          "legendFormat": "성공률",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "전체 P50 / P95 / P99 응답시간",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 10,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=\"/api/voice/voice\"}[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/api/voice/voice\"}[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/api/voice/voice\"}[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "STT / Agent / TTS 단계별 평균 레이턴시",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"stt\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"stt\"}[5m]) * 1000",
          "legendFormat": "STT",
          "refId": "A"
        },
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"agent\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"agent\"}[5m]) * 1000",
          "legendFormat": "Agent",
          "refId": "B"
        },
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"tts\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"tts\"}[5m]) * 1000",
          "legendFormat": "TTS",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "단계별 레이턴시 시계열",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"stt\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"stt\"}[5m]) * 1000",
          "legendFormat": "STT",
          "refId": "A"
        },
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"agent\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"agent\"}[5m]) * 1000",
          "legendFormat": "Agent",
          "refId": "B"
        },
        {
          "expr": "rate(voice_pipeline_stage_duration_seconds_sum{stage=\"tts\"}[5m]) / rate(voice_pipeline_stage_duration_seconds_count{stage=\"tts\"}[5m]) * 1000",
          "legendFormat": "TTS",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "초당 음성 요청 수",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/api/voice/voice\"}[1m])",
          "legendFormat": "요청/초",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Subagent별 호출 횟수",
      "description": "각 서브그래프(도메인)의 누적 호출 횟수",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "expr": "agent_subgraph_duration_seconds_count",
          "legendFormat": "{{subgraph}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "전체 처리 소요시간 (STT -> Agent -> TTS)",
      "description": "음성 파이프라인 전체 소요 시간 (실행시간 1번)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_total_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "rate(pipeline_total_duration_seconds_sum[$__rate_interval]) / rate(pipeline_total_duration_seconds_count[$__rate_interval]) * 1000",
          "legendFormat": "평균",
          "refId": "B"
        }
      ]
    },
    {
      "id": 17,
      "title": "에이전트 라우팅 소요시간 (Tool 선택 전)",
      "description": "에이전트 라우팅(Tool 선택 전) 소요 시간 (실행시간 2번)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_routing_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "rate(agent_routing_duration_seconds_sum[$__rate_interval]) / rate(agent_routing_duration_seconds_count[$__rate_interval]) * 1000",
          "legendFormat": "평균",
          "refId": "B"
        }
      ]
    },
    {
      "id": 18,
      "title": "에이전트 전체 소요시간 (Tool 실행 및 DB 적재 포함)",
      "description": "에이전트 전체(Supervisor -> Tool -> DB적재) 소요 시간 (실행시간 3번)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(agent_total_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "rate(agent_total_duration_seconds_sum[$__rate_interval]) / rate(agent_total_duration_seconds_count[$__rate_interval]) * 1000",
          "legendFormat": "평균",
          "refId": "B"
        }
      ]
    }
  ]
}