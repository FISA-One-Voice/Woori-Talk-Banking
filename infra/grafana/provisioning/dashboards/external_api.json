{
  "title": "외부 API 상태",
  "uid": "woori-external-api",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "Asia/Seoul",
  "tags": [
    "woori"
  ],
  "panels": [
    {
      "id": 1,
      "title": "Clova STT 에러율",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "datasource",
        "uid": "-- Dashboard --"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "panelId": 6,
          "datasource": {
            "type": "datasource",
            "uid": "-- Dashboard --"
          }
        }
      ],
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "sum"
            ]
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binaryOperation",
            "binary": {
              "left": "Clova STT 성공",
              "right": "Clova STT 실패",
              "operator": "+"
            },
            "alias": "total"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binaryOperation",
            "binary": {
              "left": "Clova STT 실패",
              "right": "total",
              "operator": "/"
            },
            "alias": "STT 에러율"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "STT 에러율"
              ]
            }
          }
        }
      ]
    },
    {
