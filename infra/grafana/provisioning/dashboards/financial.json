                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT $__timeGroupAlias(created_at - INTERVAL '9 hours', $__interval, 0), COUNT(*) FILTER (WHERE status = 'completed') AS \"성공\", COUNT(*) FILTER (WHERE status = 'failed') AS \"실패\" FROM transactions WHERE tx_type = 'transfer' AND created_at >= to_timestamp($__unixEpochFrom())::timestamp AND created_at <= to_timestamp($__unixEpochTo())::timestamp GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "rawQuery": true
        }
      ]
    },
