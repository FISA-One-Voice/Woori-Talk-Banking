      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "성공"
            },
            "properties": [
              {
                "id": "color",
