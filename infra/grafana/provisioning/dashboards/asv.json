      "targets": [
        {
          "refId": "A",
          "alias": "pass",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "opensearch"
          },
          "index": "voice_pipeline",
          "query": "asv_result:pass",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "timeField": "timestamp",
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "timestamp",
              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": "0"
              }
            }
          ]
        },
        {
          "refId": "B",
          "alias": "fail",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "opensearch"
          },
          "index": "voice_pipeline",
          "query": "asv_result:fail",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "timeField": "timestamp",
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "timestamp",
              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": "0"
              }
            }
          ]
        }
      ]
    },
    {
      "id": 5,
      "title": "ASV 인증 소요시간",
      "description": "ASV 인증 API 호출의 P95 및 평균 소요시간 추이",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(asv_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "rate(asv_duration_seconds_sum[$__rate_interval]) / rate(asv_duration_seconds_count[$__rate_interval]) * 1000",
          "legendFormat": "평균",
          "refId": "B"
        }
      ]
    },
