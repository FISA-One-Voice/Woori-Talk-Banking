      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "alias": "총 인증 시도",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "opensearch"
          },
          "index": "voice_pipeline",
          "query": "asv_result:pass OR asv_result:fail",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "timeField": "timestamp",
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "timestamp",
              "id": "2",
              "settings": {
                "interval": "1h",
                "min_doc_count": "0"
              }
            }
          ]
        }
      ],
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "sum"
            ]
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "P50 / P95 / P99 소요시간",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 500
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(asv_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(asv_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(asv_duration_seconds_bucket[$__rate_interval])) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "pass / fail 인증 시계열",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
