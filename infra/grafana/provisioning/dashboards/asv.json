{
  "title": "ASV 화자 인증 현황",
  "uid": "woori-asv",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timezone": "Asia/Seoul",
  "tags": [
    "woori"
  ],
  "panels": [
    {
      "id": 1,
      "title": "ASV 통과율",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "opensearch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "alias": "pass",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "opensearch"
          },
          "index": "voice_pipeline",
          "query": "asv_result:pass",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "timeField": "timestamp",
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "timestamp",
              "id": "2",
              "settings": {
                "interval": "1h",
                "min_doc_count": "0"
              }
            }
          ]
        },
        {
          "refId": "B",
          "alias": "total",
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "opensearch"
          },
          "index": "voice_pipeline",
          "query": "asv_result:pass OR asv_result:fail",
          "metrics": [
            {
              "type": "count",
              "id": "1"
            }
          ],
          "timeField": "timestamp",
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "timestamp",
              "id": "2",
              "settings": {
                "interval": "1h",
                "min_doc_count": "0"
              }
            }
          ]
        }
      ],
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "sum"
            ]
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binaryOperation",
            "binary": {
              "left": "pass",
              "right": "total",
              "operator": "/"
            },
            "alias": "통과율"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "통과율"
              ]
            }
          }
        }
      ]
    },
    {
      "id": 2,
