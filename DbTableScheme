-- 테이블: accounts
CREATE TABLE public.accounts (
    user_id uuid NOT NULL,
    account_id uuid NOT NULL,
    balance bigint NOT NULL,
    created_at timestamp without time zone,
    is_primary boolean NOT NULL,
    bank_name character varying NOT NULL,
    account_number character varying NOT NULL,
    account_type character varying,
    alias character varying
);

-- 테이블: transactions
CREATE TABLE public.transactions (
    tx_id uuid NOT NULL,
    user_id uuid NOT NULL,
    from_account_id uuid NOT NULL,
    recipient_id uuid,
    auto_order_id uuid,
    amount bigint NOT NULL,
    tx_type USER-DEFINED NOT NULL,
    status USER-DEFINED NOT NULL,
    idempotency_key character varying(36),
    created_at timestamp without time zone,
    memo character varying,
    to_bank_name character varying,
    to_account_number character varying,
    to_name character varying,
    category character varying
);

-- 테이블: standing_orders
CREATE TABLE public.standing_orders (
    order_id uuid NOT NULL,
    user_id uuid NOT NULL,
    from_account_id uuid NOT NULL,
    recipient_id uuid NOT NULL,
    amount bigint NOT NULL,
    cycle USER-DEFINED NOT NULL,
    scheduled_day integer,
    scheduled_dow integer,
    terms_agreed_at timestamp without time zone NOT NULL,
    status USER-DEFINED NOT NULL,
    next_execution_at timestamp without time zone,
    created_at timestamp without time zone,
    password_hash character varying NOT NULL
);

-- 테이블: events
CREATE TABLE public.events (
    created_at timestamp without time zone,
    event_id uuid NOT NULL,
    is_active boolean,
    start_at timestamp without time zone NOT NULL,
    end_at timestamp without time zone NOT NULL,
    description text,
    banner_image_url character varying,
    title character varying NOT NULL
);

-- 테이블: voice_profiles
CREATE TABLE public.voice_profiles (
    profile_id uuid NOT NULL,
    user_id uuid NOT NULL,
    embedding_vector USER-DEFINED NOT NULL,
    registered_at timestamp without time zone,
    updated_at timestamp without time zone
);

-- 테이블: event_participations
CREATE TABLE public.event_participations (
    participation_id uuid NOT NULL,
    user_id uuid NOT NULL,
    event_id uuid NOT NULL,
    participated_at timestamp without time zone
);

-- 테이블: registered_recipients
CREATE TABLE public.registered_recipients (
    recipient_id uuid NOT NULL,
    user_id uuid NOT NULL,
    created_at timestamp without time zone,
    recipient_name character varying NOT NULL,
    alias character varying NOT NULL,
    bank_name character varying NOT NULL,
    account_number character varying NOT NULL
);

-- 테이블: users
CREATE TABLE public.users (
    user_id uuid NOT NULL,
    birthday date,
    tts_speed double precision,
    created_at timestamp without time zone,
    embedding_vector USER-DEFINED,
    name character varying NOT NULL,
    phone character varying NOT NULL,
    address character varying,
    resident_number character varying,
    disability_type character varying,
    pin_hash character varying NOT NULL
);