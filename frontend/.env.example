# ================================================================
# frontend/.env.example
#
# 이 파일을 복사해서 frontend/.env 를 만들고 본인 IP를 입력하세요.
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
#
# frontend/.env 는 .gitignore 에 포함되어 있어 커밋되지 않습니다.
# expo start 실행 시 자동으로 읽힙니다. (Expo SDK 49+ 기본 지원)
#
# IP 확인 방법:
#   Windows → PowerShell: ipconfig   (IPv4 주소)
#   Mac     → 터미널: ipconfig getifaddr en0
# ================================================================

EXPO_PUBLIC_API_BASE_URL=http://본인_IP:8000
